# Copy this to .streamlit/secrets.toml for local development (that file is
# gitignored). On Streamlit Community Cloud, paste this same content into
# your app's Settings -> Secrets instead — never commit real credentials.
#
# This section is entirely optional: the app works with zero AWS setup,
# fetching directly from DTCC every time. Configuring this just adds a
# persistent, shared cache of already-parsed days so repeat loads (and other
# users/sessions) skip the DTCC download + parse. See README.md for the
# S3 bucket + IAM setup steps.

[aws]
access_key_id = "AKIA..."
secret_access_key = "..."
region_name = "us-east-1"
bucket_name = "your-bucket-name"
